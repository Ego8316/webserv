+std::string		utils::extractPath(std::string full_path)
+{
+	if (full_path.find("/") == std::string::npos)
+		return ("");
+	else if (full_path.rfind("/") == full_path.size() - 1)
+		return (full_path);
+	return (full_path.substr(0, full_path.rfind("/")));
+}
